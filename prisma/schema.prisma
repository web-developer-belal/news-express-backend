// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String       @id
  photo     String?   @db.VarChar(200)
  name      String    @db.VarChar(200)
  email     String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]

  emailVerified Boolean   @default(false)
  image         String?
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model News {
  id            Int       @id @default(autoincrement())
  categoryId    Int?
  subCategoryId Int?
  thumbnail     String?   @db.VarChar(200)
  galleryImages Json      @default("[]") // Array of image URLs
  title         String    @db.VarChar(255)
  slug          String    @unique @db.VarChar(255)
  content       String    @db.Text
  excerpt       String?   @db.VarChar(500)
  status        String    @default("draft") // draft, published, archived
  views         Int       @default(0)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Meta data
  metaTitle       String? @db.VarChar(200)
  metaDescription String? @db.VarChar(300)
  metaKeywords    String? @db.VarChar(200)

  // SEO & Social
  seo         Json?        @default("{}")
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  comments    Comment[]

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@map("news")
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique @db.VarChar(100)
  slug          String        @unique @db.VarChar(100)
  icon          String?       @db.VarChar(200)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  news          News[]
  subCategories SubCategory[]

  @@index([slug])
  @@map("categories")
}

model SubCategory {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  categoryId Int // References Category
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  news       News[]
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([categoryId])
  @@map("sub_categories")
}

// ============================================
// COMMENT MODEL - Comments on News
// ============================================

model Comment {
  id          Int      @id @default(autoincrement())
  content     String   @db.Text
  authorName  String   @db.VarChar(100)
  authorEmail String   @db.VarChar(100)
  authorPhoto String?  @db.VarChar(200)
  newsId      Int // References News
  parentId    Int? // For nested replies (self-reference)
  isApproved  Boolean  @default(false)
  isSpam      Boolean  @default(false)
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  news        News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  replies     Reply[]

  @@index([newsId])
  @@index([parentId])
  @@index([isApproved])
  @@map("comments")
}

// ============================================
// REPLY MODEL - Replies to Comments
// ============================================

model Reply {
  id          Int      @id @default(autoincrement())
  content     String   @db.Text
  authorName  String   @db.VarChar(100)
  authorEmail String   @db.VarChar(100)
  authorPhoto String?  @db.VarChar(200)
  commentId   Int
  isApproved  Boolean  @default(false)
  isSpam      Boolean  @default(false)
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([isApproved])
  @@map("replies")
}

// ============================================
// ADMIN MODEL - Separate Admin Table
// ============================================

model Admin {
  id        Int       @id @default(autoincrement())
  photo     String?   @db.VarChar(200)
  name      String    @db.VarChar(200)
  email     String    @unique
  password  String // Hashed password
  role      String    @default("admin") // admin, super_admin
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Security
  twoFactorAuth Boolean @default(false)
  refreshToken  String? @db.VarChar(500)

  @@map("admins")
}

